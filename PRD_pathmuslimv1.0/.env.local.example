# Supabase Configuration
# Get these values from: supabase status
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXX

# Service role key (for server-side operations only)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXX

# Application Configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Email Provider Configuration
# Options: console (logs to console), smtp (real email)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@pathmuslim.example.com

# Database URL (for direct connection, optional)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
